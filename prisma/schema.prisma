generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                 String     @id @default(cuid())
  name               String
  technology         String
  country            String
  capacityMw         Float
  status             String
  ao                 String     @default("Non renseigne")
  priority           String     @default("Medium")
  caseType           String     @default("Base")
  region             String     @default("Non renseignee")
  tariff             Float      @default(0)
  commissioningYear  Int        @default(0)
  debtSizingCentralW Float?
  debtSizingLowW     Float?
  investorCurveW     Float?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  scenarios          Scenario[]
}

model AuroraCurve {
  id         String   @id @default(cuid())
  year       Int      @unique
  high       Float
  central    Float
  low        Float
  technology String
  updatedAt  DateTime @default(now())
}

