// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                 String     @id @default(cuid())
  name               String
  technology         String
  country            String
  capacityMw         Float
  status             String
  ao                 String     @default("Non renseigne")
  priority           String     @default("Medium")
  caseType           String     @default("Base")
  region             String     @default("Non renseignee")
  tariff             Float      @default(0)
  commissioningYear  Int        @default(0)
  debtSizingCentralW Float?
  debtSizingLowW     Float?
  investorCurveW     Float?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  scenarios          Scenario[]
}

model AuroraCurve {
  id         String   @id @default(cuid())
  year       Int      @unique
  high       Float
  central    Float
  low        Float
  technology String
  updatedAt  DateTime @default(now())
}

model Scenario {
  id                       String   @id @default(cuid())
  name                     String
  capex                    Float
  surfaceHa                Float?
  prixModuleUSDWc          Float?
  tauxEURUSD               Float?
  boSCtWc                  Float?
  raccordementOuvrageKEuro Float?   @map("raccordementOuvrageK€")
  tarifQPKEuroPerMW        Float?   @map("tarifQPk€PerMW")
  apportAffaireMode        String?
  apportAffaireValeur      Float?
  opex                     Float
  yieldMwh                 Float
  yieldP90Mwh              Float?
  tariff                   Float
  debtRate                 Float
  projectLifeYears         Int      @default(30)
  degradationRate          Float    @default(0.3)
  discountRate             Float    @default(6)
  debtInterestRate         Float    @default(4)
  debtMaturityYears        Int      @default(20)
  tariffInflationRate      Float    @default(0)
  opexInflationRate        Float    @default(2)
  contractDuration         Int?
  constructionYears        Int?
  assuranceRate            Float?
  inflationAssurance       Float?
  balancingCost            Float?
  omFixedEuroKwc           Float?
  mraEuroKwc               Float?
  backOfficeKeuro          Float?
  diversOpexKeuro          Float?
  loyerMode                String?
  loyerValeur              Float?
  loyerInflation           Float?
  inflationOM              Float?
  inflationMRA             Float?
  inflationBackOffice      Float?
  inflationDivers          Float?
  methodeTaxes             String?
  tauxTFCommune            Float?
  tauxTFEPCI               Float?
  tauxTSE                  Float?
  tauxGEMAPI               Float?
  tauxTEOM                 Float?
  tauxCFECommune           Float?
  tauxCFEEPCI              Float?
  tauxCCI                  Float?
  prixTerrainHa            Float?
  abattTerrain             Float?
  inflationTaxes           Float?
  iferRate1                Float?
  iferRate2                Float?
  iferRpn                  Float?
  inflationAurora          Float?
  dscrTarget               Float?
  debtTenorYears           Int?
  dscrSchedule             String?
  gearingMaxPct            Float?   @map("gearingMax")
  structuringFeeRate       Float?
  tauxIS                   Float?
  amortDuree               Int?
  ccaApportKeuro           Float?
  ccaRemunRate             Float?
  dsraMonths               Int?
  ccaBloque                Boolean?
  devFeesKEuroPerMW        Float?
  tauxISEntreprise         Float?
  contingencyRate          Float?
  longueurModule           Float?
  largeurModule            Float?
  txAmenagementRate        Float?
  coefArcheo               Float?
  legalFeesKEuro           Float?   @map("legalFeesK€")
  technicalDDKEuro         Float?   @map("technicalDDK€")
  arrangerFeesRate         Float?
  participantFeesRate      Float?
  bankFeesPLTKEuroPerMW    Float?   @map("bankFeesPLTK€PerMW")
  interimFinancingRate     Float?
  commitmentFeesRate       Float?
  unavailability           Float?
  indemnitesImmoKeuro      Float?
  aleasOpexRate            Float?
  tauxTSECfe               Float?
  tauxGEMAPICfe            Float?
  coefDegressif            Float?
  taxeFinaleSizingKeuro    Float?
  agentFeeAnnuelKeuro      Float?
  dsrfFeeRate              Float?
  capacityCertificateMw    Float?
  goStartYear              Int?
  goPriceBase              Float?
  curveIndexAn1            Float?
  fonciereBienEuroWc       Float?
  batimentsFonciersKeuro   Float?
  modRetraitementKeuro     Float?
  valeurTerrainKeuro       Float?
  // Inputs moteur de calibration BP (seed-driven, pas de champ formulaire). Nullable → rétrocompat
  // stricte : scénario legacy (colonnes null) recompute à l'identique. opexEngagementsKeuroByYear =
  // tableau k€ an-par-an encodé JSON (comme dscrSchedule) ; margeFactFigeeKeuro = k€ (null = boucle
  // endogène, 0 = figée). Cf scripts/read_bp_matrix.ts (engineOnly) et app/lib/finance/engine.ts.
  opexEngagementsKeuroByYear String?
  margeFactFigeeKeuro        Float?
  // Marge facturable AMORTISSABLE (item 7) : part du MOD (r32 « Dont Marge facturable ») déjà
  // financée dans le CAPEX (via indemnitesImmoKeuro) mais amortie en Type 2 par le BP (C_D&A r21).
  // null → base Type 2 inchangée (rétrocompat stricte).
  margeFactAmortissableKeuro Float?
  // TF / CFE appliquées par le BP (C_P50 r191 / r192), tableaux k€ an-par-an encodés JSON (item 4).
  // Priment sur la base calculée quand présentes ; null → base calculée (rétrocompat stricte).
  tfKeuroByYear              String?
  cfeKeuroByYear             String?
  // Démantèlement appliqué par le BP (C_P50 r195), tableau k€ an-par-an encodé JSON (item 2) :
  // poste OPEX an25-29 uniquement, constant non indexé. null → 0 (rétrocompat stricte).
  demantelementKeuroByYear   String?
  // MRA appliquée par le BP (C_P50 r189), tableau k€ an-par-an encodé JSON (item 6) : courbe en
  // PALIERS (renouvellement onduleurs), déjà indexée 2 %/an. Prime sur le scalaire mraEuroKwc
  // quand présente ; null → formule scalaire plate (rétrocompat stricte).
  mraKeuroByYear             String?
  // Financing fees RÉELLEMENT APPLIQUÉS par le BP (Inp_Assumption r548, € → k€) : valeur an0
  // routée dans le CAPEX (calculateCapexDetails) qui NEUTRALISE le recalcul par taux
  // (calculateFinancingFees). null → recalcul par taux 7 composants (rétrocompat stricte).
  financingFeesKeuro         Float?
  // MÉTHODES Phase 3 (projets neufs sans série routée — la série routée garde la priorité) :
  // • demantelementEuroMWc : coût de démantèlement en €/MWc (null → défaut moteur 10 000, =
  //   les 25 BP au centime : total r195 / MWc = 10 000 exactement partout).
  // • demantelementTiming  : "fin_de_vie" (défaut : total étalé an25-29, non indexé) |
  //   "construction" (provisionné en année 0, poste CAPEX No D&A).
  // • mraProfil            : "paliers" (défaut : forme universelle 6/11/16/13 dérivée des BP
  //   « Input ») | "plat" (rares sites type Mur-de-Sologne).
  demantelementEuroMWc       Float?
  demantelementTiming        String?
  mraProfil                  String?
  // • engagementsKeuroAn1  : MÉTHODE engagements (tranche 2) — montant année 1 en k€, indexé
  //   2 %/an : engagements(y) = an1 × 1,02^(y-1). Fallback quand opexEngagementsKeuroByYear est
  //   absente (la série routée r199 garde la priorité). PAS de défaut imposé : l'an1/MWc des
  //   25 BP varie de 369 à 9 586 €/MWc (médiane ≈ 2 626) → null → comportement actuel (0).
  engagementsKeuroAn1        Float?
  // MÉTHODE TF/CFE Phase 3 (tranche 4, docs/PHASE3_METHODES.md §4.4) — sélecteur d'assiette
  // AUTO + override (§7.2) et taux département (§7.3). La série routée tfKeuroByYear/
  // cfeKeuroByYear garde la PRIORITÉ ABSOLUE.
  // • prixAchatTerrainEuro : prix d'achat du terrain en € (template J298). NON-null → active le
  //   sélecteur Phase 3 : > 0 → assiette « comptable » ; sinon « appréciation directe » template.
  //   null (et methodeAssiette null) → branche taxes legacy STRICTEMENT inchangée (rétrocompat).
  // • methodeAssiette : override manuel "comptable" | "appreciation_directe" ; null → AUTO
  //   (dérivé du prix d'achat — rattrape les erreurs de saisie type Digoin).
  // • tauxTFDepartement : taux TFPB département, compté EN PLUS du communal si ≠ 0 (décimal).
  prixAchatTerrainEuro       Float?
  methodeAssiette            String?
  tauxTFDepartement          Float?
  dscr                     Float
  npv                      Float
  irr                      Float
  lcoe                     Float
  isReference              Boolean  @default(false)
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
