// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                String     @id @default(cuid())
  name              String
  technology        String
  country           String
  capacityMw        Float
  status            String
  ao                String     @default("Non renseigne")
  priority          String     @default("Medium")
  caseType          String     @default("Base")
  region            String     @default("Non renseignee")
  tariff            Float      @default(0)
  commissioningYear Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  scenarios         Scenario[]
}

model Scenario {
  id                  String  @id @default(cuid())
  name                String
  capex               Float
  opex                Float
  yieldMwh            Float
  yieldP90Mwh         Float?
  tariff              Float
  debtRate            Float
  projectLifeYears    Int     @default(30)
  degradationRate     Float   @default(0.3)
  discountRate        Float   @default(6)
  debtInterestRate    Float   @default(4)
  debtMaturityYears   Int     @default(20)
  tariffInflationRate Float   @default(0)
  opexInflationRate   Float   @default(2)
  dscrTarget          Float?
  debtTenorYears      Int?
  dscrSchedule        String?
  gearingMax          Float?
  structuringFeeRate  Float?
  tauxIS              Float?
  amortDuree          Int?
  ccaApportKeuro      Float?
  ccaRemunRate        Float?
  dsraMonths          Int?
  ccaBloque           Boolean?
  devFeesKEuroPerMW   Float?
  tauxISEntreprise    Float?
  dscr                Float
  npv                 Float
  irr                 Float
  lcoe                Float
  isReference         Boolean @default(false)
  projectId           String
  project             Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
