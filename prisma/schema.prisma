// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                 String     @id @default(cuid())
  name               String
  technology         String
  country            String
  capacityMw         Float
  status             String
  ao                 String     @default("Non renseigne")
  priority           String     @default("Medium")
  caseType           String     @default("Base")
  region             String     @default("Non renseignee")
  tariff             Float      @default(0)
  commissioningYear  Int        @default(0)
  debtSizingCentralW Float?
  debtSizingLowW     Float?
  investorCurveW     Float?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  scenarios          Scenario[]
}

model AuroraCurve {
  id         String   @id @default(cuid())
  year       Int      @unique
  high       Float
  central    Float
  low        Float
  technology String
  updatedAt  DateTime @default(now())
}

model Scenario {
  id                       String   @id @default(cuid())
  name                     String
  capex                    Float
  surfaceHa                Float?
  prixModuleUSDWc          Float?
  tauxEURUSD               Float?
  boSCtWc                  Float?
  raccordementOuvrageKEuro Float?   @map("raccordementOuvrageKâ‚¬")
  tarifQPKEuroPerMW        Float?   @map("tarifQPkâ‚¬PerMW")
  apportAffaireMode        String?
  apportAffaireValeur      Float?
  opex                     Float
  yieldMwh                 Float
  yieldP90Mwh              Float?
  tariff                   Float
  debtRate                 Float
  projectLifeYears         Int      @default(30)
  degradationRate          Float    @default(0.3)
  discountRate             Float    @default(6)
  debtInterestRate         Float    @default(4)
  debtMaturityYears        Int      @default(20)
  tariffInflationRate      Float    @default(0)
  opexInflationRate        Float    @default(2)
  contractDuration         Int?
  assuranceRate            Float?
  inflationAssurance       Float?
  balancingCost            Float?
  omFixedEuroKwc           Float?
  mraEuroKwc               Float?
  backOfficeKeuro          Float?
  diversOpexKeuro          Float?
  loyerMode                String?
  loyerValeur              Float?
  loyerInflation           Float?
  inflationOM              Float?
  inflationMRA             Float?
  inflationBackOffice      Float?
  inflationDivers          Float?
  dscrTarget               Float?
  debtTenorYears           Int?
  dscrSchedule             String?
  gearingMaxPct            Float?   @map("gearingMax")
  structuringFeeRate       Float?
  tauxIS                   Float?
  amortDuree               Int?
  ccaApportKeuro           Float?
  ccaRemunRate             Float?
  dsraMonths               Int?
  ccaBloque                Boolean?
  devFeesKEuroPerMW        Float?
  tauxISEntreprise         Float?
  legalFeesKEuro           Float?   @map("legalFeesKâ‚¬")
  technicalDDKEuro         Float?   @map("technicalDDKâ‚¬")
  arrangerFeesRate         Float?
  participantFeesRate      Float?
  bankFeesPLTKEuroPerMW    Float?   @map("bankFeesPLTKâ‚¬PerMW")
  interimFinancingRate     Float?
  commitmentFeesRate       Float?
  dscr                     Float
  npv                      Float
  irr                      Float
  lcoe                     Float
  isReference              Boolean  @default(false)
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
